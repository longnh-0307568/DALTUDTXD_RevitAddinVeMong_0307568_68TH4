<Window x:Class="AddinVeMong.Views.MainWindowView"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:ribbon="clr-namespace:System.Windows.Controls.Ribbon;assembly=System.Windows.Controls.Ribbon"
        Title="Addin Revit" Height="600" Width="800" WindowStartupLocation="CenterScreen">

    <Window.Resources>

        <Style TargetType="TextBox">

            <Setter Property="Height" Value="28"/>

            <Setter Property="Margin" Value="0,5"/>

            <Setter Property="VerticalContentAlignment" Value="Center"/>

            <Setter Property="Padding" Value="5,0"/>

            <Setter Property="Template">

                <Setter.Value>

                    <ControlTemplate TargetType="TextBox">

                        <Border x:Name="border" 

                            BorderBrush="#CCC" 

                            BorderThickness="1" 

                            CornerRadius="5" 

                            Background="White">

                            <ScrollViewer x:Name="PART_ContentHost" Focusable="false" HorizontalScrollBarVisibility="Hidden" VerticalScrollBarVisibility="Hidden"/>

                        </Border>



                        <ControlTemplate.Triggers>

                            <Trigger Property="IsFocused" Value="true">

                                <Setter TargetName="border" Property="BorderBrush" Value="#2196F3"/>

                                <Setter TargetName="border" Property="BorderThickness" Value="1.5"/>

                                <Setter TargetName="border" Property="Effect">

                                    <Setter.Value>

                                        <DropShadowEffect BlurRadius="8" ShadowDepth="0" Color="#2196F3" Opacity="0.5"/>

                                    </Setter.Value>

                                </Setter>

                            </Trigger>



                            <Trigger Property="IsMouseOver" Value="true">

                                <Setter TargetName="border" Property="BorderBrush" Value="#999"/>

                            </Trigger>

                        </ControlTemplate.Triggers>

                    </ControlTemplate>

                </Setter.Value>

            </Setter>

        </Style>

    </Window.Resources>



    <DockPanel>
        <ribbon:Ribbon DockPanel.Dock="Top" Margin="0,-22,0,0">
            <ribbon:Ribbon.ApplicationMenu>
                <ribbon:RibbonApplicationMenu Visibility="Collapsed"/>
            </ribbon:Ribbon.ApplicationMenu>
            <ribbon:RibbonTab Header="THIẾT KẾ MÓNG">
                <ribbon:RibbonGroup Header="Loại móng" Background="White">
                    <ribbon:RibbonSplitButton Label="Móng đơn" LargeImageSource="/AddinVeMong;component/Assets/Images/IsolatedFooting.png">
                        <ribbon:RibbonMenuItem Header="Đúng Tâm" Command="{Binding CentricInput}" ImageSource="/AddinVeMong;component/Assets/Images/CentricFooting.png"/>
                        <ribbon:RibbonMenuItem Header="Lệch Tâm" Command="{Binding EccentricInput}" ImageSource="/AddinVeMong;component/Assets/Images/EccentricFooting.PNG"/>
                    </ribbon:RibbonSplitButton>
                </ribbon:RibbonGroup>

                <ribbon:RibbonGroup Header="Thao tác" Background="White">
                    <ribbon:RibbonButton Label="Vẽ" LargeImageSource="/AddinVeMong;component/Assets/Images/Draw.png"/>
                </ribbon:RibbonGroup>
            </ribbon:RibbonTab>

            <ribbon:RibbonTab Header="TRỢ GIÚP">
                <ribbon:RibbonGroup Header="Thông tin" Background="White">
                    <ribbon:RibbonButton Label="Hướng Dẫn" LargeImageSource="/AddinVeMong;component/Assets/Images/Help.png"/>
                </ribbon:RibbonGroup>
            </ribbon:RibbonTab>
        </ribbon:Ribbon>

        <ScrollViewer VerticalScrollBarVisibility="Auto">
            <Grid Margin="20">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="380"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0" Margin="0,0,20,0">
                    <Expander Header="1. THÔNG SỐ HÌNH HỌC (mm)" IsExpanded="True" Margin="0,0,0,10" FontWeight="Bold">
                        <Grid Margin="10,5,0,0">
                            <Grid x:Name="InputCentric" Visibility="{Binding InputCentricVisibility}">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>

                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>

                                <Label Content="Chiều dài (l):" Grid.Row="0" FontWeight="Normal"/>
                                <TextBox x:Name="txtLengthCentric" Grid.Row="0" Grid.Column="1"/>

                                <Label Content="Chiều rộng (b):" Grid.Row="1" FontWeight="Normal"/>
                                <TextBox x:Name="txtWidthCentric" Grid.Row="1" Grid.Column="1"/>

                                <Label Content="Chiều dày móng (h):" Grid.Row="2" FontWeight="Normal"/>
                                <TextBox x:Name="txtHeightCentric" Grid.Row="2" Grid.Column="1"/>

                                <Label Content="Góc xoay:" Grid.Row="3" FontWeight="Normal"/>

                                <ComboBox x:Name="cbRotationCentric" Grid.Row="3" Grid.Column="1" Height="28"  HorizontalAlignment="Left" Margin="0,5">
                                    <ComboBoxItem Content="0° (Dọc)" IsSelected="True"/>
                                    <ComboBoxItem Content="90° (Ngang)"/>
                                </ComboBox>
                            </Grid>

                            <Grid x:Name="InputEccentric" Visibility="{Binding InputEccentricVisibility}">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>

                                <Label Content="Chiều dài (l):" Grid.Row="0" FontWeight="Normal"/>
                                <TextBox x:Name="txtL_LechTam" Grid.Row="0" Grid.Column="1"/>

                                <Label Content="Chiều rộng (b):" Grid.Row="1" FontWeight="Normal"/>
                                <TextBox x:Name="txtB_LechTam" Grid.Row="1" Grid.Column="1"/>

                                <Label Content="Chiều cao móng (h):" Grid.Row="2" FontWeight="Normal"/>
                                <TextBox x:Name="txtH_LechTam" Grid.Row="2" Grid.Column="1"/>

                                <Label Content="Độ lệch (e):" Grid.Row="3" FontWeight="Normal"/>
                                <TextBox x:Name="txtE_LechTam" Grid.Row="3" Grid.Column="1"/>
                            </Grid>
                        </Grid>
                    </Expander>

                    <Expander Header="2. THÔNG SỐ CỐT THÉP" IsExpanded="False" Margin="0,0,0,10" FontWeight="Bold">
                        <Grid Margin="10,5,0,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>

                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>

                            <Label Content="Thép phương X:" Grid.Row="0" FontWeight="Normal"/>
                            <TextBox x:Name="txtQtyX" Grid.Row="0" Grid.Column="1" Margin="0,5,5,5"/>
                            <TextBlock Text="Φ" Grid.Row="0" Grid.Column="2" VerticalAlignment="Center" Margin="5,0"/>

                            <ComboBox x:Name="cbPhiX" Grid.Row="0" Grid.Column="3" Width="60" Height="28">
                                <ComboBoxItem Content="8" IsSelected="True"/>
                                <ComboBoxItem Content="10"/>
                                <ComboBoxItem Content="12"/>
                            </ComboBox>

                            <Label Content="Thép phương Y:" Grid.Row="1" FontWeight="Normal"/>
                            <TextBox x:Name="txtQtyY" Grid.Row="1" Grid.Column="1" Margin="0,5,5,5"/>
                            <TextBlock Text="Φ" Grid.Row="1" Grid.Column="2" VerticalAlignment="Center" Margin="5,0"/>

                            <ComboBox x:Name="cbPhiY" Grid.Row="1" Grid.Column="3" Width="60" Height="28">
                                <ComboBoxItem Content="8" IsSelected="True"/>
                                <ComboBoxItem Content="10"/>
                                <ComboBoxItem Content="12"/>
                            </ComboBox>
                        </Grid>
                    </Expander>

                </StackPanel>
                <Border Grid.Column="1" Background="#F0F0F0" CornerRadius="10" MinHeight="300">
                    <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                        <TextBlock Text="[ HÌNH ẢNH MINH HỌA MÓNG ]" Foreground="#888" HorizontalAlignment="Center"/>
                        <TextBlock Text="(Cập nhật theo thông số nhập liệu)" FontSize="10" Foreground="#AAA" HorizontalAlignment="Center"/>
                    </StackPanel>
                </Border>
            </Grid>
        </ScrollViewer>
    </DockPanel>
</Window>